#!/bin/sh

# staged 파일 목록 확인
STAGED_TS=$(git diff --cached --name-only | grep -E '\.ts$')

# .ts 파일이 없으면 검사 생략
if [ -z "$STAGED_TS" ]; then
  echo "⏭ TypeScript 파일 변경 없음 — 검사 생략"
  exit 0
fi

cd web

echo "🔍 [1/3] TypeScript 타입 체크..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ 타입 오류가 있습니다. 커밋이 중단됩니다."
  exit 1
fi

echo "🔍 [2/3] ESLint 린트 검사..."
npx eslint "src/**/*.ts" --max-warnings 0
if [ $? -ne 0 ]; then
  echo "❌ 린트 오류가 있습니다. 커밋이 중단됩니다."
  exit 1
fi

echo "🔍 [3/3] 테스트 실행..."
npx vitest run
if [ $? -ne 0 ]; then
  echo "❌ 테스트 실패. 커밋이 중단됩니다."
  exit 1
fi

echo "✅ 모든 검사 통과. 커밋을 진행합니다."
